# API server
INQUIRY_API_PORT=8787
INQUIRY_ALLOWED_ORIGINS=http://localhost:5173

# Optional email SMTP (leave host empty to use console sender)
Email_Smtp_Host=mail.amcco.ps
Email_Smtp_Port=465
Email_Smtp_UseSsl=true
Email__Smtp__UserName=a.mahameed@amcco.ps
Email_Smtp_Password=CHANGE_ME_WITH_ACCOUNT_PASSWORD
MAIL_INCOMING_HOST=mail.amcco.ps
MAIL_IMAP_PORT=993
MAIL_POP3_PORT=995
MAIL_SMTP_REQUIRE_AUTH=true
MAIL_TLS_REJECT_UNAUTHORIZED=true

# Where inquiry messages are delivered
INQUIRY_MAIL_TO=a.mahameed@amcco.ps
INQUIRY_MAIL_FROM=a.mahameed@amcco.ps
INQUIRY_MAIL_FROM_NAME=AMC Website Inquiry
# Optional absolute path override for embedded email logo
# INQUIRY_EMAIL_LOGO_PATH=E:/dev/AMC1/AMC/src/assets/brand/logo-silver.svg

# Frontend endpoint (use Vite proxy in local development)
VITE_INQUIRY_API_URL=/api/inquiry

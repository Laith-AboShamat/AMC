# API server
INQUIRY_API_PORT=8787
INQUIRY_ALLOWED_ORIGINS=http://localhost:5173

# Mailbox credentials and transport
MAIL_USERNAME=a.mahameed@amcco.ps
MAIL_PASSWORD=CHANGE_ME
MAIL_INCOMING_HOST=mail.amcco.ps
MAIL_IMAP_PORT=993
MAIL_POP3_PORT=995
